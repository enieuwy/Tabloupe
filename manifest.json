{
  "manifest_version": 2,
  "name": "Focus Tab Groups",
  "version": "1.0.9",
  "description": "Collapses and expands Firefox tab groups based on macOS Focus mode via mac-command-centre.",
  "browser_specific_settings": {
    "gecko": {
      "id": "focus-tab-groups@local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "tabGroups",
    "tabs",
    "storage",
    "notifications",
    "alarms",
    "ws://127.0.0.1/*"
  ],
  "content_security_policy": "script-src 'self'; object-src 'self'; connect-src 'self' ws://127.0.0.1:8767;",
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_action": {
    "default_title": "Focus Tab Groups"
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  }
}