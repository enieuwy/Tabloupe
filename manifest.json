{
  "manifest_version": 2,
  "name": "Focus Tab Groups",
  "version": "1.2.1",
  "description": "Collapses and expands Firefox tab groups based on macOS Focus mode via mac-command-centre.",
  "browser_specific_settings": {
    "gecko": {
      "id": "focus-tab-groups@local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "tabGroups",
    "tabs",
    "storage",
    "notifications",
    "alarms",
    "ws://127.0.0.1/*"
  ],
  "optional_permissions": [
    "https://*/*"
  ],
  "content_security_policy": "script-src 'self'; object-src 'self'; connect-src 'self' https: ws://127.0.0.1:8767;",
  "commands": {
    "search-tabs": {
      "description": "Open the tab search overlay"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "tabsearch.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "browser_action": {
    "default_title": "Focus Tab Groups",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  }
}
