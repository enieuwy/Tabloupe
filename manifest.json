{
  "manifest_version": 2,
  "name": "Tab Lens",
  "version": "1.2.4",
  "description": "Save and switch views of your Firefox tab groups. Collapse the groups you don't need; tabs stay open. Optional macOS Focus automation.",
  "browser_specific_settings": {
    "gecko": {
      "id": "focus-tab-groups@local",
      "strict_min_version": "139.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "tabGroups",
    "tabs",
    "storage",
    "notifications",
    "alarms",
    "ws://127.0.0.1/*"
  ],
  "optional_permissions": [
    "https://*/*"
  ],
  "content_security_policy": "script-src 'self'; object-src 'self'; connect-src 'self' https: ws://127.0.0.1:8767;",
  "commands": {
    "search-tabs": {
      "description": "Open the tab search overlay"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "tabsearch.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_action": {
    "default_title": "Tab Lens",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  }
}
